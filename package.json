{
  "name": "@ngx-rock/memoize-pipe",
  "version": "22.0.0",
  "private": true,
  "description": "Development workspace for @ngx-rock/memoize-pipe",
  "scripts": {
    "ng": "ng",
    "build": "ng build memoize-pipe-lib",
    "watch": "ng build memoize-pipe-lib --watch --configuration development",
    "test": "ng test memoize-pipe-lib",
    "lint": "pnpm run lint:duplicates",
    "lint:duplicates": "clone-alert",
    "badge:duplicates": "clone-alert --format shields --no-fail-on-violation",
    "copy-libdocs": "cp README.md README_RU.md LICENSE dist/memoize-pipe-lib",
    "lib:local:publish": "npm run build && npm run copy-libdocs && cd dist/memoize-pipe-lib && npm publish --registry http://localhost:4873",
    "lib:publish": "npm run build && npm run copy-libdocs && cd dist/memoize-pipe-lib && npm publish --access=public"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/common": "^22.0.4",
    "@angular/compiler": "^22.0.4",
    "@angular/compiler-cli": "^22.0.4",
    "@angular/core": "^22.0.4",
    "@angular/platform-browser": "^22.0.4",
    "clone-alert": "^1.1.3",
    "jsdom": "^29.1.1",
    "ng-packagr": "^22.0.0",
    "tslib": "^2.8.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  },
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ngx-rock/memoize-pipe/issues"
  },
  "homepage": "https://github.com/ngx-rock/memoize-pipe#readme",
  "packageManager": "pnpm@10.12.3+sha512.467df2c586056165580ad6dfb54ceaad94c5a30f80893ebdec5a44c5aa73c205ae4a5bb9d5ed6bb84ea7c249ece786642bbb49d06a307df218d03da41c317417"
}
